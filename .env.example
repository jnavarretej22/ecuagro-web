# Copia este archivo a `.env` y rellena los valores.
# Nunca subas `.env` al repositorio.

# Neon PostgreSQL (Connection string con sslmode=require)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Groq (Fase 6+; clave solo en servidor, nunca en el cliente)
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Prueba manual POST /api/dev/groq-test (solo desarrollo; no activar en producción pública)
ENABLE_GROQ_TEST_ROUTE=

# Sesión: clave HS256 para firmar el JWT (mínimo 32 caracteres, sin espacios extra al pegar). Fase 3+
SESSION_SECRET=

# Usuario admin inicial (seed `npm run db:seed`; ver Fase 4 del plan)
BOOTSTRAP_ADMIN_USER=
BOOTSTRAP_ADMIN_PASSWORD=

# Futuro GPT‑4o / OpenAI (Fase 10; MVP sigue con Groq)
# VISION_PROVIDER: groq (defecto) | openai (stub: sin llamada HTTP aún)
VISION_PROVIDER=groq
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o
